{
  "name": "aptos-explorer",
  "version": "1.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "engines": {
    "node": "^24 || ^25"
  },
  "pnpm": {
    "overrides": {
      "@aptos-labs/aptos-client": "^4.0.0",
      "@aptos-labs/wallet-standard": "^1.0.0",
      "@aptos-labs/ts-sdk": "^6.3.0",
      "axios": "1.15.0",
      "d3-array": ">=3.0.0",
      "d3-color": ">=3.1.0",
      "d3-dispatch": ">=3.0.0",
      "d3-drag": ">=3.0.0",
      "d3-ease": ">=3.0.0",

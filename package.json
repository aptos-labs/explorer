    "prettier": "^3.3.2",
    "ts-results": "^3.3.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.2",
    "vite-plugin-svgr": "^4.2.0",
    "vitest": "^1.6.0"
  }

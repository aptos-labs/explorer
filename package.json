{
  "name": "aptos-explorer",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "engines": {
    "node": "^24 || ^25"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "7.1.3",
    "@aptos-labs/wallet-adapter-react": "8.3.3",
    "@download/blockies": "1.0.3",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.1.1",
    "@mui/material": "9.1.2",
    "@noble/hashes": "2.2.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "@tanstack/react-virtual": "3.14.5",
    "@uiw/react-json-view": "2.0.0-alpha.43",
    "chart.js": "4.5.1",
    "d3-geo": "3.1.1",
    "d3-selection": "3.0.0",
    "d3-zoom": "3.0.0",
    "date-fns": "4.4.0",
    "diff": "9.0.0",
    "es-toolkit": "1.49.0",
    "highlightjs-move": "0.3.0",
    "js-cookie": "3.0.8",
    "pako": "2.2.0",
    "react": "19.2.7",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.7",
    "react-helmet-async": "3.0.0",
    "react-hook-form": "7.80.0",
    "react-simple-maps": "3.0.0",
    "react-syntax-highlighter": "16.1.1"
  },
  "scripts": {
    "routes:generate": "tsr generate",
    "prebuild": "pnpm routes:generate",
    "prelint": "pnpm routes:generate",
    "pretest": "pnpm routes:generate",
    "precheck": "pnpm routes:generate",
    "predev": "pnpm routes:generate",
    "prestart": "pnpm routes:generate",
    "start": "vite dev --port 3000",
    "dev": "vite dev --port 3030",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "tsc --noEmit && biome lint .",
    "fmt": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage",
    "ci:verify": "pnpm routes:generate && tsc --noEmit && biome lint . && vitest --run --coverage && vite build",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@codecov/vite-plugin": "2.0.1",
    "@netlify/vite-plugin-tanstack-start": "1.3.16",
    "@playwright/test": "1.61.1",
    "@tanstack/react-query-devtools": "5.101.2",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-cli": "1.167.18",
    "@tanstack/router-plugin": "1.168.19",
    "@testing-library/react": "16.3.2",
    "@types/js-cookie": "3.0.6",
    "@types/jsdom": "28.0.3",
    "@types/pako": "2.0.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-simple-maps": "3.0.6",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "rollup-plugin-visualizer": "7.0.1",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plugin-compression": "0.5.1",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.9"
  }
}
